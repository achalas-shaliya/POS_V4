# ── Database ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_root
DB_NAME=pos_db
DB_USER=pos_user
DB_PASSWORD=change_me_pass

# ── JWT — generate strong random strings for production ───────────────────────
# Example (PowerShell): [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }))
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS — set to your frontend's public URL ──────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Frontend API URL — must be reachable from the user's BROWSER ──────────────
# Local:      http://localhost:5000/api/v1
# Production: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1

# ── Cash drawer serial port (leave blank to disable) ──────────────────────────
# Windows (direct):  COM3
# Linux/Docker:      /dev/ttyUSB0   (also uncomment 'devices' in docker-compose.yml)
CASH_DRAWER_PORT=
